#!/bin/bash
#PBS -N mlp_test
#PBS -J 0-5
#PBS -l select=1:ncpus=1:mem=1gb
#PBS -l walltime=00:10:00
#PBS -q main
#PBS -A UMIC0126
#PBS -o logs/mlp_test.out
#PBS -e logs/mlp_test.err
#PBS -j oe

# ── Environment ───────────────────────────────────────────────────────────────
cd "/glade/u/home/rbhandarkar/Inputs/Load Regression"
module load conda
conda activate assetra_gl

# ── Paths ─────────────────────────────────────────────────────────────────────
SCRIPT_DIR="/glade/u/home/rbhandarkar/Inputs/Load Regression"
DATA_DIR="${SCRIPT_DIR}"
MODEL_DIR="${SCRIPT_DIR}/mlp_tuned_results"
OUT_DIR="${SCRIPT_DIR}/mlp_test_results"

mkdir -p "${SCRIPT_DIR}/logs"
mkdir -p "${OUT_DIR}"

# ── Run worker ────────────────────────────────────────────────────────────────
echo "Starting task ${PBS_ARRAY_INDEX} on $(hostname) at $(date)"

python "${SCRIPT_DIR}/mlp_test_worker.py" \
    --task-id  "${PBS_ARRAY_INDEX}" \
    --data-dir "${DATA_DIR}" \
    --model-dir "${MODEL_DIR}" \
    --outdir   "${OUT_DIR}"

EXIT_CODE=$?
echo "Task ${PBS_ARRAY_INDEX} finished at $(date) with exit code ${EXIT_CODE}"
exit ${EXIT_CODE}
